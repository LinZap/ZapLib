{
  "metadata": [
    {
      "src": [
        {
          "src": "../ZapLib",
          "files": [ "**/*.csproj" ]
        }
      ],
      "dest": "api",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "properties": {
        "TargetFramework": "net472"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "**/*.{md,yml}" ],
        "exclude": [ "_site/**", "obj/**" ]
      }
    ],
    "resource": [
      {
        "files": [ "images/**" ]
      }
    ],
    "output": "_site",
    "globalMetadata": {
      "_appName": "ZapLib",
      "_appTitle": "ZapLib Documentation",
      "_appFooter": "Copyright © ZapLin. ZapLib is released under the MIT License.",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/LinZap/ZapLib",
        "branch": "master"
      }
    },
    "template": [ "default", "modern" ],
    "postProcessors": [ "ExtractSearchIndex" ],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}
