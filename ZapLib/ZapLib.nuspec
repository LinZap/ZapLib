<?xml version="1.0"?>
<package >
  <metadata>
    <id>ZapLib</id>
    <version>2.5.0</version>
    <title>ZapLib</title>
    <authors>Zap Lin</authors>
    <owners>Zap Lin</owners>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <description>
      Inspired by jQuery and Node.js, ZapLib is a lightweight C# library that helps developers accomplish complex tasks with minimal code — HTTP requests, SQL Server / Oracle queries, .NET Web API extensions, SMTP mail, regular expressions, and more.

      📚 Documentation: https://linzap.github.io/ZapLib/
      🔧 Source &amp; Issues: https://github.com/LinZap/ZapLib
    </description>
    <releaseNotes>
      v2.5.0 — Stable release of the 2.5.x line. Includes:
        * NEW OracleSQL class for Oracle database queries (managed driver, no Oracle Client needed)
        * Security: patches CVEs in MailKit, MimeKit, Microsoft.Owin, Newtonsoft.Json
        * Renamed misspelled public methods (Connet -> Connect, BuildconnString -> BuildConnectionString, SetRequestContnet -> SetRequestContent). Old names kept as [Obsolete] aliases for backward compatibility; they will be removed in v3.0.
        * NEW documentation site: https://linzap.github.io/ZapLib/
      v2.4.12 (previous stable) — SQL AlwaysOn read-only routing support
      v1.22.0 (LTS for .NET 4.5)

      Full changelog: https://github.com/LinZap/ZapLib/blob/master/CHANGELOG.md
    </releaseNotes>
    <copyright>Copyright Zap Lin 2018-2026</copyright>
    <tags>Zap Lib API HTTP Fetch SQL Oracle WebAPI SignalR SMTP Mailer Regex JSON Crypto</tags>
    <projectUrl>https://linzap.github.io/ZapLib/</projectUrl>
    <readme>docs\README.md</readme>
    <license type="expression">MIT</license>
    <icon>docs\icon.png</icon>
  </metadata>
  <files>
    <file src="..\README.md" target="docs\" />
    <file src="..\icon.png" target="docs\" />
  </files>
</package>
